{
  "name": "fonio-clone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:remote": "npx @cloudflare/next-on-pages && npx wrangler pages dev .vercel/output/static --binding AUTH_SECRET=dev-secret-change-me-in-production-32chars-minimum --compatibility-date=2024-09-23 --compatibility-flags=nodejs_compat",
    "d1:sync": "npx wrangler d1 export fonio-db --remote --output=.wrangler/remote-dump.sql && npx wrangler d1 execute fonio-db --local --file=.wrangler/remote-dump.sql",
    "build": "next build",
    "pages:build": "npx @cloudflare/next-on-pages",
    "preview": "wrangler pages dev .vercel/output/static --binding AUTH_SECRET=dev-secret-change-me-in-production-32chars-minimum --compatibility-date=2024-09-23 --compatibility-flags=nodejs_compat",
    "deploy": "npx @cloudflare/next-on-pages && npx wrangler pages deploy .vercel/output/static --project-name=fonio-clone --commit-dirty=true",
    "d1:migrate": "wrangler d1 execute fonio-db --local --file=./migrations/001_schema.sql",
    "d1:migrate:prod": "wrangler d1 execute fonio-db --remote --file=./migrations/001_schema.sql",
    "lint": "next lint"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@telnyx/webrtc": "^2.25.25",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "lucide-react": "^0.323.0",
    "next": "15.5.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "retell-sdk": "^5.10.2",
    "stripe": "^14.14.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "telnyx": "^6.29.7",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20240129.0",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.52",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "wrangler": "^4.79.0"
  }
}
