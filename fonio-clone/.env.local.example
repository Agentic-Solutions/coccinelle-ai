# ═══════════════════════════════════════
# FONIO CLONE - Variables d'environnement
# ═══════════════════════════════════════
# Full Cloudflare Stack (D1 + R2 + Pages)
# Copie ce fichier en .env.local et remplis les valeurs

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VoxyPhone

# Auth (Better Auth)
AUTH_SECRET=une-cle-secrete-de-32-caracteres-minimum
# Optionnel: OAuth providers
# GOOGLE_CLIENT_ID=xxx
# GOOGLE_CLIENT_SECRET=xxx

# Cloudflare (pour dev local uniquement)
# En production, D1 et R2 sont liés automatiquement via wrangler.toml
CLOUDFLARE_ACCOUNT_ID=9c27dcacc982caff25e46d0756c87837
CLOUDFLARE_D1_DATABASE_ID=REMPLACER_PAR_TON_DATABASE_ID

# Telnyx
TELNYX_API_KEY=KEYxxx
TELNYX_PUBLIC_KEY=xxx
TELNYX_CONNECTION_ID=xxx
TELNYX_MESSAGING_PROFILE_ID=xxx
TELNYX_WEBHOOK_SIGNING_KEY=xxx

# RetellAI
RETELL_API_KEY=xxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Resend (Email)
RESEND_API_KEY=re_xxx
