# =============================================================================
# VoixIA — Variables d'environnement
# =============================================================================
# Copiez ce fichier en .env et remplissez vos cles API
# Usage: cp .env.example .env && nano .env
# =============================================================================

# ---------------------------------------------------------------------------
# LiveKit — Serveur WebRTC (transport audio)
# ---------------------------------------------------------------------------
# Cle API et secret pour l'authentification JWT LiveKit
# En dev: les valeurs par defaut fonctionnent. En prod: generees par deploy.sh
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret1234567890abcdef
# URL du serveur LiveKit (WebSocket)
# En dev: ws://localhost:7880 | En prod: wss://voixia.coccinelle.ai
LIVEKIT_URL=ws://localhost:7880

# ---------------------------------------------------------------------------
# Deepgram — Speech-to-Text (STT)
# ---------------------------------------------------------------------------
# Cle API Deepgram pour la transcription audio en temps reel
# Inscription: https://console.deepgram.com/signup
# Modele utilise: nova-2 (francais)
DEEPGRAM_API_KEY=CHANGEZ_MOI

# ---------------------------------------------------------------------------
# Mistral AI — Large Language Model (LLM)
# ---------------------------------------------------------------------------
# Cle API Mistral pour le cerveau de l'agent vocal
# Inscription: https://console.mistral.ai/
# Modele utilise: mistral-large-latest
MISTRAL_API_KEY=CHANGEZ_MOI

# ---------------------------------------------------------------------------
# ElevenLabs — Text-to-Speech (TTS)
# ---------------------------------------------------------------------------
# Cle API ElevenLabs pour la synthese vocale
# Inscription: https://elevenlabs.io/
# Voix utilisee: voix francaise feminine (configurable dans agent/worker.py)
ELEVENLABS_API_KEY=CHANGEZ_MOI

# ---------------------------------------------------------------------------
# Coccinelle.ai — API CRM Backend
# ---------------------------------------------------------------------------
# URL de l'API Coccinelle (Cloudflare Workers)
COCCINELLE_API_URL=https://coccinelle-api.youssef-amrouche.workers.dev
# Token d'authentification pour les appels API machine-to-machine
# Generer via: l'endpoint /api/auth/service-token
COCCINELLE_API_TOKEN=CHANGEZ_MOI

# ---------------------------------------------------------------------------
# Twilio — Telephonie SIP (appels entrants/sortants)
# ---------------------------------------------------------------------------
# Identifiants Twilio pour la gestion des appels
# Console: https://console.twilio.com/
TWILIO_ACCOUNT_SID=CHANGEZ_MOI
TWILIO_AUTH_TOKEN=CHANGEZ_MOI
# Numero de telephone Twilio (format E.164)
TWILIO_PHONE_NUMBER=+33939035760

# ---------------------------------------------------------------------------
# Configuration optionnelle
# ---------------------------------------------------------------------------
# Niveau de log (debug, info, warn, error)
LOG_LEVEL=info
# Nom de domaine du serveur LiveKit (production uniquement)
# LIVEKIT_HOST=voixia.coccinelle.ai
